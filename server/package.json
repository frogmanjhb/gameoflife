{
  "name": "game-of-life-server",
  "version": "1.0.0",
  "description": "Backend server for CivicLab",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "rimraf dist && node node_modules/typescript/lib/tsc.js && node node_modules/copyfiles/index.js src/database/*.sql dist/database/ --flat && node node_modules/copyfiles/index.js migrations/*.sql dist/migrations/ --flat && node node_modules/copyfiles/index.js seed-town-hub.js dist/ && node copy-wordle-words.js",
    "start": "node dist/server.js",
    "create-super-admin": "node create-super-admin.js",
    "migrate:multi-tenant": "node run-multi-tenant-migration.js",
    "migrate:weekly-loans": "node run-sql-migration.js migrations/004_weekly_loan_payments.sql",
    "migrate:global-jobs": "node run-sql-migration.js migrations/064_add_global_jobs_for_all_schools.sql",
    "migrate:land-prices": "node run-sql-migration.js migrations/066_land_biome_price_increase.sql",
    "migrate:land-town-class": "node run-sql-migration.js migrations/067_land_town_class.sql",
    "migrate:succulent-desert-prices": "node run-sql-migration.js migrations/068_succulent_desert_price_increase.sql",
    "migrate:karoo-desert-prices": "node run-sql-migration.js migrations/069_karoo_desert_price_increase.sql",
    "migrate:karoo-desert-prices-2": "node run-sql-migration.js migrations/070_karoo_desert_price_increase_2.sql",
