    "migrate:doctor-illness-cure": "node run-sql-migration.js migrations/077_add_doctor_illness_cure_flow.sql",
    "migrate:insurance-broker": "node run-sql-migration.js migrations/078_add_insurance_broker_approval.sql",
    "migrate:accountant-assignments": "node run-sql-migration.js migrations/079_accountant_student_assignments.sql",
