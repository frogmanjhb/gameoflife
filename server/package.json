    "@types/pg": "^8.10.9",
    "@types/uuid": "^9.0.7",
    "bcryptjs": "^2.4.3",
    "copyfiles": "^2.4.1",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-validator": "^7.0.1",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.11.3",
    "rimraf": "^6.1.2",
    "sqlite3": "^5.1.7",
    "tsx": "^4.6.2",
    "typescript": "^5.3.3",
    "uuid": "^9.0.1"
  }
